# =====================================================
# CFA SAT Tracker .gitignore
# =====================================================

# -----------------------------------------------------
# OS
# -----------------------------------------------------
.DS_Store
Thumbs.db
*.swp
*.swo

# -----------------------------------------------------
# Secrets / env files
# -----------------------------------------------------
.env
.env.local
.env.*.local
*.env
cookies.txt

# -----------------------------------------------------
# Python / Django
# -----------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so

# Virtual envs
venv/
.venv/
env/
ENV/

# Django
*.log
local_settings.py
db.sqlite3
db.sqlite3-journal
media/
staticfiles/

# Django migrations cache (but keep migration files committed)
*.pyc

# -----------------------------------------------------
# Node / React
# -----------------------------------------------------
node_modules/
frontend/build/
frontend/.env
frontend/.env.local
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# -----------------------------------------------------
# IDE
# -----------------------------------------------------
.vscode/
.idea/
*.iml

# -----------------------------------------------------
# Misc
# -----------------------------------------------------
coverage/
.pytest_cache/
.coverage
htmlcov/
